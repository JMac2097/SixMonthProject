// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ConnectionType {
  trello
  gitlab
}

enum SyncRunStatus {
  running
  succeeded
  failed
}

enum SyncItemAction {
  created
  skipped
  failed
}

model ConnectionProfile {
  id          String         @id @default(cuid())
  type        ConnectionType
  name        String
  baseUrl     String?
  credentials Json
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  trelloRules Rule[]         @relation("RuleTrelloConnection")
  gitlabRules Rule[]         @relation("RuleGitLabConnection")
}

model Rule {
  id                  String            @id @default(cuid())
  name                String

  trelloConnectionId  String
  trelloConnection    ConnectionProfile @relation("RuleTrelloConnection", fields: [trelloConnectionId], references: [id])
  trelloBoardId       String
  trelloListIds       Json
  trelloLabelIds      Json?

  gitlabConnectionId  String
  gitlabConnection    ConnectionProfile @relation("RuleGitLabConnection", fields: [gitlabConnectionId], references: [id])
  gitlabProjectId     Int
  gitlabProjectPath   String?
  gitlabDefaultLabels Json

  titleTemplate       String
  descriptionTemplate String
  includeTrelloLabels Boolean           @default(true)
  fixedLabels         Json

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  syncRuns            SyncRun[]
}

model SyncRun {
  id         String        @id @default(cuid())
  ruleId     String
  rule       Rule          @relation(fields: [ruleId], references: [id])
  status     SyncRunStatus @default(running)
  startedAt  DateTime      @default(now())
  finishedAt DateTime?

  items      SyncItem[]

  @@index([ruleId, startedAt])
}

model SyncItem {
  id            String         @id @default(cuid())
  syncRunId     String
  syncRun       SyncRun        @relation(fields: [syncRunId], references: [id])
  trelloCardId  String
  action        SyncItemAction
  gitlabIssueIid Int?
  gitlabIssueUrl String?
  error         String?

  createdAt     DateTime       @default(now())

  @@index([syncRunId])
  @@index([trelloCardId])
}

model CardIssueLink {
  id               String   @id @default(cuid())
  trelloCardId     String
  gitlabConnectionId String
  gitlabProjectId  Int
  gitlabIssueIid   Int
  gitlabIssueUrl   String
  createdAt        DateTime @default(now())

  @@unique([trelloCardId, gitlabConnectionId, gitlabProjectId])
  @@index([gitlabConnectionId, gitlabProjectId])
}
